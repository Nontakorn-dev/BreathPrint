# Copy to .env and fill in. (.env is git-ignored — NEVER commit a real key.)
# Get a Typhoon key at https://opentyphoon.ai

TYPHOON_API_KEY=
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2.1-instruct

# Real audio model (HuggingFace) — optional; falls back to deterministic mock if unset/unavailable
HF_AUDIO_MODEL=MIT/ast-finetuned-audioset-10-10-0.4593

# CORS — your deployed frontend origin, e.g. https://web-ashen-ten-40.vercel.app
CORS_ORIGIN=*
